# Database
DATABASE_URL=postgresql://postwave:postwave@localhost:5432/postwave

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GITHUB_REPO=https://github.com/YOUR_USER/X-Post-Creator
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Token encryption (32 bytes base64 — openssl rand -base64 32)
TOKEN_ENCRYPTION_KEY=

# X (Twitter) API — https://developer.x.com
X_CLIENT_ID=
X_CLIENT_SECRET=
X_CALLBACK_URL=http://localhost:3000/api/x/callback

# Resend — optional, for failure alert emails — https://resend.com
RESEND_API_KEY=
EMAIL_FROM=PostWave <notifications@yourdomain.com>

# Storage: local (Docker/default) or s3 (cloud deploys)
STORAGE_TYPE=local
# S3-compatible storage (when STORAGE_TYPE=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# Optional: Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Optional: rate limiting (self-hosted public instances)
RATE_LIMIT_ENABLED=false

# Worker
WORKER_CONCURRENCY=5
