# PostWave local / deploy configuration
# Copy to .env and fill in values. For CLI/desktop, run: postwave init

POSTWAVE_DATA_DIR=
POSTWAVE_CONFIG_PATH=

APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GITHUB_REPO=https://github.com/DevomB/X-Post-Creator

# Token encryption (32 bytes base64 — openssl rand -base64 32)
TOKEN_ENCRYPTION_KEY=

# X (Twitter) API — https://developer.x.com
X_CLIENT_ID=
X_CLIENT_SECRET=
X_CALLBACK_URL=http://127.0.0.1:8787/callback

# Optional: failure alert emails — https://resend.com
RESEND_API_KEY=
EMAIL_FROM=PostWave <notifications@yourdomain.com>
NOTIFY_EMAIL=

# Deploy daemon health check
WORKER_HEALTH_PORT=8081

# Optional: desktop IPC when CLI daemon exposes JSON-RPC
POSTWAVE_IPC_PORT=9847
