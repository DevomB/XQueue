{
  "name": "xqueue",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @xqueue/web dev",
    "dev:worker": "pnpm --filter @xqueue/worker dev",
    "build": "pnpm --filter @xqueue/shared build && pnpm --filter @xqueue/web build && pnpm --filter @xqueue/worker build",
    "db:generate": "pnpm --filter @xqueue/web db:generate",
    "db:migrate": "pnpm --filter @xqueue/web db:migrate",
    "db:push": "pnpm --filter @xqueue/web db:push",
    "db:studio": "pnpm --filter @xqueue/web db:studio",
    "test": "pnpm --filter @xqueue/web test && pnpm --filter @xqueue/shared test",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20"
  }
}
