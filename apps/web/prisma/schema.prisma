generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
}

enum PostStatus {
  DRAFT
  SCHEDULED
  QUEUED
  PUBLISHED
  FAILED
  CANCELLED
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  emailVerified    DateTime?
  name             String?
  image            String?
  passwordHash     String?
  stripeCustomerId String?         @unique
  plan             Plan            @default(FREE)
  timezone         String          @default("UTC")
  acceptedTermsAt  DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  accounts         Account[]
  sessions         Session[]
  xAccounts        XAccount[]
  scheduledPosts   ScheduledPost[]
  usageCounters    UsageCounter[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model XAccount {
  id              String          @id @default(cuid())
  userId          String
  xUserId         String
  xUsername       String
  accessTokenEnc  String          @db.Text
  refreshTokenEnc String          @db.Text
  tokenExpiresAt  DateTime
  scopes          String
  connectedAt     DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledPosts  ScheduledPost[]

  @@unique([userId, xUserId])
}

model ScheduledPost {
  id            String     @id @default(cuid())
  userId        String
  xAccountId    String?
  text          String     @db.Text
  scheduledAt   DateTime?
  timezone      String     @default("UTC")
  status        PostStatus @default(DRAFT)
  mediaUrls     String[]   @default([])
  isLinkPost    Boolean    @default(false)
  xTweetId      String?
  failureReason String?    @db.Text
  attemptCount  Int        @default(0)
  bullJobId     String?
  publishedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  xAccount      XAccount?  @relation(fields: [xAccountId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status, scheduledAt])
}

model UsageCounter {
  userId          String
  month           String
  postsScheduled  Int    @default(0)
  postsPublished  Int    @default(0)
  linkPostsUsed   Int    @default(0)
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, month])
}
