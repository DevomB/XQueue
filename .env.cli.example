# PostWave CLI / desktop local configuration
# Copy values into ~/.postwave/config.json via `postwave init`

X_CLIENT_ID=
X_CLIENT_SECRET=
X_CALLBACK_URL=http://127.0.0.1:8787/callback

# openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Optional
POSTWAVE_DATA_DIR=
POSTWAVE_IPC_PORT=9847
NOTIFY_EMAIL=
RESEND_API_KEY=
EMAIL_FROM=PostWave <notifications@yourdomain.com>
